# Supabase client config (Project Settings > API in the Supabase dashboard)
# Both of these are safe to expose to the browser.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY

# The service-role key is NEVER used in the front-end and NEVER committed.
# Do not prefix it with VITE_ (Vite exposes every VITE_ variable to the browser).
# Keep it only in local CLI env or server-side scripts.
# SUPABASE_SERVICE_ROLE_KEY=
